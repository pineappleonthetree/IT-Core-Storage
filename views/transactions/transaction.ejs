<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>transections</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Prompt', sans-serif;
            background-color: #0E1324;
            color: white;
        }

        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #0E1324;
        }

        ::-webkit-scrollbar-thumb {
            background: #1B2A47;
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #4BA3E3;
        }

        /* Style สำหรับจัดระเบียบข้อความที่ยาวเกินไปในตาราง */
        .truncate-text {
            max-width: 150px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        input[type="date"] {
            color-scheme: dark;
        }

        ::-webkit-calendar-picker-indicator {
            cursor: pointer;
            opacity: 0.7;
            transition: 0.2s;
            filter: invert(0.8) sepia(1) hue-rotate(180deg) saturate(3);
        }

        ::-webkit-calendar-picker-indicator:hover {
            opacity: 1;
        }
    </style>
</head>

<body class="overflow-x-hidden">

    <%- include('../partials/header_with_path', { path1: 'ประวัติธุรกรรม' , url_1: '/transactions' }) %>

        <div class="ml-[110px] mt-[100px] p-10 min-h-[calc(100vh-100px)] relative z-10">

            <div class="absolute right-32 top-10 opacity-5 pointer-events-none">
                <i class="fa-solid fa-boxes-stacked text-[400px]"></i>
            </div>

            <div class="mb-8">
                <h1 class="text-[32px] font-semibold mb-1">ประวัติธุรกรรม</h1>
                <p class="text-[#999] text-sm">ตรวจสอบประวัติการเคลื่อนไหวสินค้า ได้ที่นี่</p>
            </div>

            <div class="flex items-center gap-6 mb-8 text-[15px]">
                <div>
                    รายการทั้งหมด <span class="font-bold ml-1">
                        <%= typeof totalRecords !=='undefined' ? totalRecords : 0 %>
                    </span>
                </div>

                <div class="flex items-center gap-3">
                    <span class="text-[#999]">วันที่</span>

                    <input type="date" id="startDate" name="startDate"
                        value="<%= typeof query !== 'undefined' && query.start ? query.start : '' %>"
                        class="bg-[#182642] text-[#69B4E3] border border-[#69B4E3]/30 px-3 py-1.5 rounded-md outline-none cursor-pointer hover:bg-[#1E2E4D] focus:border-[#4BA3E3] transition text-sm">

                    <span class="text-[#999]">ถึง</span>

                    <input type="date" id="endDate" name="endDate"
                        value="<%= typeof query !== 'undefined' && query.end ? query.end : '' %>"
                        class="bg-[#182642] text-[#69B4E3] border border-[#69B4E3]/30 px-3 py-1.5 rounded-md outline-none cursor-pointer hover:bg-[#1E2E4D] focus:border-[#4BA3E3] transition text-sm">

                    <button onclick="applyFilters()"
                        class="bg-[#3fa9f5] hover:bg-[#1c92d2] text-white px-3 py-1.5 rounded-md transition text-sm flex items-center gap-2 shadow-md ml-2">
                        <i class="fa-solid fa-magnifying-glass text-xs"></i> ตกลง
                    </button>
                </div>
            </div>

            <div class="w-full relative">

                <div class="flex items-end justify-between mb-0 relative z-20">
                    <div class="flex" id="tab-buttons">
                        <button onclick="switchTab('inbound')" id="btn-inbound"
                            class="tab-btn bg-[#182642] text-white px-10 py-3 font-medium rounded-t-lg border-b-0 shadow-[0_-5px_10px_rgba(0,0,0,0.1)] transition-colors">
                            สินค้าเข้า
                        </button>
                        <button onclick="switchTab('outbound')" id="btn-outbound"
                            class="tab-btn bg-[#0A1020] text-[#7A839E] hover:text-white px-10 py-3 font-medium rounded-t-lg border-b-0 hover:bg-[#182642]/50 transition-colors">
                            เบิกจ่าย
                        </button>
                        <button onclick="switchTab('adjust')" id="btn-adjust"
                            class="tab-btn bg-[#0A1020] text-[#7A839E] hover:text-white px-10 py-3 font-medium rounded-t-lg border-b-0 hover:bg-[#182642]/50 transition-colors">
                            ปรับแก้ไข
                        </button>
                    </div>

                    <div class="flex flex-col items-end pb-2 gap-2">
                        <div id="dynamic-summary-text" class="text-[13px] text-[#999] mr-2">
                            รับเข้าทั้งหมด <%= typeof inboundData !=='undefined' ? inboundData.length : 0 %>
                        </div>
                        <div class="flex items-center gap-3">
                            <div
                                class="relative flex items-center bg-[#0A1020] rounded-full pl-4 border border-[#2A354D] overflow-hidden">
                                <input type="text" id="searchInput"
                                    value="<%= typeof query !== 'undefined' && query.search ? query.search : '' %>"
                                    placeholder="ค้นหา ชื่อสินค้า, ผู้รับ, ผู้ส่ง" onkeypress="handleSearchEnter(event)"
                                    class="bg-transparent border-none outline-none text-[13px] text-white w-[220px] placeholder-[#666]">

                                <button onclick="applyFilters()"
                                    class="bg-[#3fa9f5] w-[40px] h-[32px] flex items-center justify-center hover:bg-blue-400 transition">
                                    <i class="fa-solid fa-magnifying-glass text-white"></i>
                                </button>
                            </div>
                            <button
                                class="flex items-center gap-2 px-4 h-[32px] bg-transparent border border-[#2A354D] rounded-full hover:bg-[#182642] text-[13px] transition text-[#999]">
                                <i class="fa-solid fa-bars-staggered"></i> กรอง
                            </button>
                            <% if (user && user.role === 'MANAGER') { %>
                                <button
                                    class="flex items-center gap-2 px-4 h-[32px] bg-[#ECC164] text-black font-semibold rounded-full hover:bg-[#f0cf85] text-[13px] transition shadow-[0_0_10px_rgba(236,193,100,0.3)]">
                                    <i class="fa-solid fa-chart-pie"></i> แดชบอร์ด
                                </button>
                                <% } %>
                        </div>
                    </div>
                </div>

                <div
                    class="bg-[#0A1020] border border-[#182642] rounded-b-xl rounded-tr-xl overflow-x-auto relative z-10 shadow-2xl min-h-[400px]">

                    <div id="tab-inbound" class="tab-content block">
                        <table class="w-full text-left text-[13px] whitespace-nowrap">
                            <thead class="bg-[#182642] text-[#69B4E3]">
                                <tr>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">ID</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">ชื่อสินค้า</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">แบรนด์</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">รหัสสินค้า</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">ประเภท</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">วันที่ เวลา</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">ผู้ส่ง</th>
                                    <th class="px-5 py-4 font-normal">เจ้าหน้าที่รับ</th>
                                </tr>
                            </thead>
                            <tbody class="text-[#D4D4D4]">
                                <% if (typeof inboundData !=='undefined' && inboundData.length> 0) { %>
                                    <% inboundData.forEach(item=> { %>
                                        <tr class="border-b border-[#182642] hover:bg-[#182642]/30 transition group">
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                TR-<%= item.trans_id %>
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <div class="flex items-center gap-3">
                                                    <div
                                                        class="w-7 h-7 bg-white rounded-full flex items-center justify-center p-1 shadow-sm shrink-0 overflow-hidden">
                                                        <img src="/images/<%= item.prod_img %>"
                                                            onerror="this.onerror=null; this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/c/c7/Intel_Core_i7_logo.svg/512px-Intel_Core_i7_logo.svg.png'"
                                                            class="object-contain w-full h-full">
                                                    </div>
                                                    <span class="truncate-text">
                                                        <%= item.prod_name %>
                                                    </span>
                                                </div>
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.brand %>
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.prod_code %>
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.prod_type %>
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= new Date(item.date_time).toLocaleString('th-TH', {
                                                    dateStyle: 'short' , timeStyle: 'short' }) %>น.
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.sender || '-' %>
                                            </td>
                                            <td class="px-5 py-4">
                                                <%= item.emp_firstname %>
                                                    <%= item.emp_lastname %>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="8" class="text-center py-10 text-gray-500">
                                                        ไม่พบข้อมูลสินค้าเข้า</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>

                    <div id="tab-outbound" class="tab-content hidden">
                        <table class="w-full text-left text-[13px] whitespace-nowrap">
                            <thead class="bg-[#182642] text-[#69B4E3]">
                                <tr>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">ID</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">ชื่อสินค้า</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">แบรนด์</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">รหัสสินค้า</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">ประเภท</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">วันที่ เวลา</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">ผู้ขอเบิก</th>
                                    <th class="px-5 py-4 font-normal">เจ้าหน้าที่ยืนยัน</th>
                                </tr>
                            </thead>
                            <tbody class="text-[#D4D4D4]">
                                <% if (typeof outboundData !=='undefined' && outboundData.length> 0) { %>
                                    <% outboundData.forEach(item=> { %>
                                        <tr class="border-b border-[#182642] hover:bg-[#182642]/30 transition group">
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                TR-<%= item.trans_id %>
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <div class="flex items-center gap-3">
                                                    <div
                                                        class="w-7 h-7 bg-white rounded-full flex items-center justify-center p-1 shadow-sm shrink-0 overflow-hidden">
                                                        <img src="/images/<%= item.prod_img %>"
                                                            onerror="this.onerror=null; this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/c/c7/Intel_Core_i7_logo.svg/512px-Intel_Core_i7_logo.svg.png'"
                                                            class="object-contain w-full h-full">
                                                    </div>
                                                    <span class="truncate-text">
                                                        <%= item.prod_name %>
                                                    </span>
                                                </div>
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.brand %>
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.prod_code %>
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.prod_type %>
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= new Date(item.date_time).toLocaleString('th-TH', {
                                                    dateStyle: 'short' , timeStyle: 'short' }) %>น.
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.requester || '-' %>
                                            </td>
                                            <td class="px-5 py-4">
                                                <%= item.emp_firstname %>
                                                    <%= item.emp_lastname %>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="8" class="text-center py-10 text-gray-500">
                                                        ไม่พบข้อมูลการเบิกจ่าย</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>

                    <div id="tab-adjust" class="tab-content hidden">
                        <table class="w-full text-left text-[13px] whitespace-nowrap">
                            <thead class="bg-[#182642] text-[#69B4E3]">
                                <tr>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">ID</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">ชื่อสินค้า</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">แบรนด์</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">รหัสสินค้า</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">ประเภท</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">วันที่ เวลา</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50 text-center">
                                        จำนวนที่ปรับ</th>
                                    <th class="px-5 py-4 font-normal border-r border-[#2A354D]/50">เจ้าหน้าที่แก้ไข</th>
                                </tr>
                            </thead>
                            <tbody class="text-[#D4D4D4]">
                                <% if (typeof adjustData !=='undefined' && adjustData.length> 0) { %>
                                    <% adjustData.forEach(item=> { %>
                                        <tr class="border-b border-[#182642] hover:bg-[#182642]/30 transition group">
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                TR-<%= item.trans_id %>
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <div class="flex items-center gap-3">
                                                    <div
                                                        class="w-7 h-7 bg-white rounded-full flex items-center justify-center p-1 shrink-0 overflow-hidden">
                                                        <img src="/images/<%= item.prod_img %>"
                                                            onerror="this.onerror=null; this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/c/c7/Intel_Core_i7_logo.svg/512px-Intel_Core_i7_logo.svg.png'"
                                                            class="object-contain w-full h-full">
                                                    </div>
                                                    <span class="truncate-text">
                                                        <%= item.prod_name %>
                                                    </span>
                                                </div>
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.brand %>
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.prod_code %>
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.prod_type %>
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= new Date(item.date_time).toLocaleString('th-TH', {
                                                    dateStyle: 'short' , timeStyle: 'short' }) %>น.
                                            </td>
                                            <td
                                                class="px-5 py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50 text-center font-medium">
                                                <%= item.amount %>
                                            </td>
                                            <td class="px-5 py-4">
                                                <%= item.emp_firstname %>
                                                    <%= item.emp_lastname %>
                                            </td>
                                        </tr>
                                        <% }) %>
                                            <% } else { %>
                                                <tr>
                                                    <td colspan="8" class="text-center py-10 text-gray-500">
                                                        ไม่พบข้อมูลการปรับแก้ไข</td>
                                                </tr>
                                                <% } %>
                            </tbody>
                        </table>
                    </div>

                </div>

                <div class="flex justify-between items-center mt-6 text-[13px] text-[#999]">
                    <div class="flex items-center gap-3">
                        จำนวนแถวต่อ 1 หน้า
                        <select
                            class="bg-transparent border border-[#2A354D] text-white rounded px-2 py-1 outline-none focus:border-[#69B4E3] cursor-pointer">
                            <option value="10" class="text-black">10</option>
                            <option value="20" class="text-black">20</option>
                            <option value="50" class="text-black">50</option>
                        </select>
                    </div>

                    <div class="flex items-center gap-2">
                        <button class="w-6 h-6 flex items-center justify-center hover:text-white transition"><i
                                class="fa-solid fa-caret-left"></i></button>
                        <button
                            class="w-6 h-6 border border-[#2A354D] rounded flex items-center justify-center text-white bg-[#182642]">1</button>
                        <button class="w-6 h-6 flex items-center justify-center hover:text-white transition">2</button>
                        <button class="w-6 h-6 flex items-center justify-center hover:text-white transition">3</button>
                        <button class="w-6 h-6 flex items-center justify-center hover:text-white transition">4</button>
                        <span class="px-1">...</span>
                        <button class="w-6 h-6 flex items-center justify-center hover:text-white transition"><i
                                class="fa-solid fa-caret-right"></i></button>
                        <button class="w-6 h-6 flex items-center justify-center hover:text-white transition"><i
                                class="fa-solid fa-forward-step"></i></button>
                    </div>
                </div>

            </div>
        </div>

        <script>
            console.log(user.role)
            const counts = {
                inbound : typeof inboundData !== 'undefined' ? inboundData.length : 0,
                outbound : typeof outboundData !== 'undefined' ? outboundData.length : 0,
                adjust : typeof adjustData !== 'undefined' ? adjustData.length : 0
        };

            function switchTab(tabId) {
                const contents = document.querySelectorAll('.tab-content');
                contents.forEach(content => {
                    content.classList.remove('block');
                    content.classList.add('hidden');
                });

                const buttons = document.querySelectorAll('.tab-btn');
                buttons.forEach(btn => {
                    btn.className = "tab-btn bg-[#0A1020] text-[#7A839E] hover:text-white px-10 py-3 font-medium rounded-t-lg border-b-0 hover:bg-[#182642]/50 transition-colors";
                });

                document.getElementById('tab-' + tabId).classList.remove('hidden');
                document.getElementById('tab-' + tabId).classList.add('block');

                document.getElementById('btn-' + tabId).className = "tab-btn bg-[#182642] text-white px-10 py-3 font-medium rounded-t-lg border-b-0 shadow-[0_-5px_10px_rgba(0,0,0,0.1)] transition-colors";

                const summaryText = document.getElementById('dynamic-summary-text');
                if (tabId === 'inbound') summaryText.textContent = `รับเข้าทั้งหมด ${counts.inbound}`;
                else if (tabId === 'outbound') summaryText.textContent = `สินค้าเบิกทั้งหมด ${counts.outbound}`;
                else if (tabId === 'adjust') summaryText.textContent = `ปรับแก้ไขทั้งหมด ${counts.adjust}`;
            }

            function applyFilters() {
                const startDate = document.getElementById('startDate').value;
                const endDate = document.getElementById('endDate').value;
                const searchInput = document.getElementById('searchInput').value;

                let url = new URL(window.location.href);

                // กรองวันที่
                if (startDate) url.searchParams.set('start', startDate);
                else url.searchParams.delete('start');

                if (endDate) url.searchParams.set('end', endDate);
                else url.searchParams.delete('end');

                // กรองข้อความค้นหา
                if (searchInput) url.searchParams.set('search', searchInput);
                else url.searchParams.delete('search');

                window.location.href = url.href;
            }

            function handleSearchEnter(e) {
                if (e.key === 'Enter') {
                    applyFilters();
                }
            }
        </script>

</body>

</html>