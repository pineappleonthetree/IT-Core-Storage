<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>transections</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Prompt', sans-serif;
            background-color: #0E1324;
            color: white;
        }

        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #0E1324; }
        ::-webkit-scrollbar-thumb { background: #1B2A47; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #4BA3E3; }

        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

        .truncate-text {
            max-width: 150px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        input[type="date"] {
            color-scheme: dark;
        }

        ::-webkit-calendar-picker-indicator {
            cursor: pointer;
            opacity: 0.7;
            transition: 0.2s;
            filter: invert(0.8) sepia(1) hue-rotate(180deg) saturate(3);
        }

        ::-webkit-calendar-picker-indicator:hover {
            opacity: 1;
        }
    </style>
</head>

<body class="overflow-x-hidden">

    <%- include('../partials/header_with_path', { path1: 'ประวัติธุรกรรม' , url_1: '/transactions' }) %>

        <div class="ml-0 lg:ml-[110px] mt-[80px] lg:mt-[100px] p-4 sm:p-6 lg:p-10 min-h-[calc(100vh-100px)] relative z-10">

            <div class="absolute right-0 lg:right-32 top-10 opacity-5 pointer-events-none hidden sm:block">
                <i class="fa-solid fa-boxes-stacked text-[200px] lg:text-[400px]"></i>
            </div>

            <div class="mb-6 lg:mb-8">
                <h1 class="text-[24px] lg:text-[32px] font-semibold mb-1">ประวัติธุรกรรม</h1>
                <p class="text-[#999] text-xs lg:text-sm">ตรวจสอบประวัติการเคลื่อนไหวสินค้า ได้ที่นี่</p>
            </div>

            <div class="flex flex-col md:flex-row md:items-center gap-4 lg:gap-6 mb-6 lg:mb-8 text-[14px] lg:text-[15px]">
                <div>
                    รายการทั้งหมด <span class="font-bold ml-1">
                        <%= typeof totalRecords !=='undefined' ? totalRecords : 0 %>
                    </span>
                </div>

                <div class="flex flex-wrap items-center gap-2 lg:gap-3">
                    <span class="text-[#999]">วันที่</span>

                    <input type="date" id="startDate" name="startDate"
                        value="<%= typeof query !== 'undefined' && query.start ? query.start : '' %>"
                        class="bg-[#182642] text-[#69B4E3] border border-[#69B4E3]/30 px-2 lg:px-3 py-1.5 rounded-md outline-none cursor-pointer hover:bg-[#1E2E4D] focus:border-[#4BA3E3] transition text-xs lg:text-sm w-[130px] lg:w-auto">

                    <span class="text-[#999]">ถึง</span>

                    <input type="date" id="endDate" name="endDate"
                        value="<%= typeof query !== 'undefined' && query.end ? query.end : '' %>"
                        class="bg-[#182642] text-[#69B4E3] border border-[#69B4E3]/30 px-2 lg:px-3 py-1.5 rounded-md outline-none cursor-pointer hover:bg-[#1E2E4D] focus:border-[#4BA3E3] transition text-xs lg:text-sm w-[130px] lg:w-auto">

                    <button onclick="applyFilters()"
                        class="bg-[#3fa9f5] hover:bg-[#1c92d2] text-white px-3 py-1.5 rounded-md transition text-xs lg:text-sm flex items-center gap-2 shadow-md lg:ml-2">
                        <i class="fa-solid fa-magnifying-glass"></i> ตกลง
                    </button>
                </div>
            </div>

            <div class="w-full relative">

                <div class="flex flex-col-reverse xl:flex-row xl:items-end justify-between mb-4 xl:mb-0 relative z-20 gap-4">
                    
                    <div class="flex w-full xl:w-auto overflow-x-auto scrollbar-hide border-b border-[#182642] xl:border-none" id="tab-buttons">
                        <button onclick="switchTab('inbound')" id="btn-inbound"
                            class="tab-btn whitespace-nowrap flex-shrink-0 bg-[#182642] text-white px-6 lg:px-10 py-3 font-medium rounded-t-lg border-b-0 shadow-[0_-5px_10px_rgba(0,0,0,0.1)] transition-colors text-sm lg:text-base">
                            สินค้าเข้า
                        </button>
                        <button onclick="switchTab('outbound')" id="btn-outbound"
                            class="tab-btn whitespace-nowrap flex-shrink-0 bg-[#0A1020] text-[#7A839E] hover:text-white px-6 lg:px-10 py-3 font-medium rounded-t-lg border-b-0 hover:bg-[#182642]/50 transition-colors text-sm lg:text-base">
                            เบิกจ่าย
                        </button>
                        <button onclick="switchTab('adjust')" id="btn-adjust"
                            class="tab-btn whitespace-nowrap flex-shrink-0 bg-[#0A1020] text-[#7A839E] hover:text-white px-6 lg:px-10 py-3 font-medium rounded-t-lg border-b-0 hover:bg-[#182642]/50 transition-colors text-sm lg:text-base">
                            ปรับแก้ไข
                        </button>
                    </div>

                    <div class="flex flex-col items-start xl:items-end w-full xl:w-auto pb-2 gap-2">
                        <div id="dynamic-summary-text" class="text-xs lg:text-[13px] text-[#999] xl:mr-2">
                            รับเข้าทั้งหมด <%= typeof inboundData !=='undefined' ? inboundData.length : 0 %>
                        </div>
                        <div class="flex flex-wrap items-center gap-2 lg:gap-3 w-full xl:w-auto">
                            <div class="relative flex flex-1 sm:flex-none items-center bg-[#0A1020] rounded-full pl-4 border border-[#2A354D] overflow-hidden">
                                <input type="text" id="searchInput"
                                    value="<%= typeof query !== 'undefined' && query.search ? query.search : '' %>"
                                    placeholder="ค้นหา ชื่อสินค้า, ผู้รับ, ผู้ส่ง" onkeypress="handleSearchEnter(event)"
                                    class="bg-transparent border-none outline-none text-xs lg:text-[13px] text-white w-full sm:w-[220px] placeholder-[#666] py-2 lg:py-0">

                                <button onclick="applyFilters()"
                                    class="bg-[#3fa9f5] w-[40px] h-full lg:h-[32px] absolute right-0 lg:relative flex items-center justify-center hover:bg-blue-400 transition">
                                    <i class="fa-solid fa-magnifying-glass text-white"></i>
                                </button>
                            </div>
                            
                            <button class="flex items-center gap-2 px-3 lg:px-4 py-2 lg:py-0 lg:h-[32px] bg-transparent border border-[#2A354D] rounded-full hover:bg-[#182642] text-xs lg:text-[13px] transition text-[#999]">
                                <i class="fa-solid fa-bars-staggered"></i> <span class="hidden sm:inline">กรอง</span>
                            </button>
                            
                            <% if (typeof user !== 'undefined' && user && user.role === 'MANAGER') { %>
                                <button class="flex items-center gap-2 px-3 lg:px-4 py-2 lg:py-0 lg:h-[32px] bg-[#ECC164] text-black font-semibold rounded-full hover:bg-[#f0cf85] text-xs lg:text-[13px] transition shadow-[0_0_10px_rgba(236,193,100,0.3)]">
                                    <i class="fa-solid fa-chart-pie"></i> <span class="hidden sm:inline">แดชบอร์ด</span>
                                </button>
                            <% } %>
                        </div>
                    </div>
                </div>

                <div class="bg-[#0A1020] border border-[#182642] rounded-xl xl:rounded-tr-xl xl:rounded-tl-none overflow-x-auto relative z-10 shadow-2xl min-h-[300px] lg:min-h-[400px]">

                    <div id="tab-inbound" class="tab-content block min-w-[800px]">
                        <table class="w-full text-left text-xs lg:text-[13px] whitespace-nowrap">
                            <thead class="bg-[#182642] text-[#69B4E3]">
                                <tr>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">ID</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">ชื่อสินค้า</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">แบรนด์</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">รหัสสินค้า</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">ประเภท</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">วันที่ เวลา</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">ผู้ส่ง</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal">เจ้าหน้าที่รับ</th>
                                </tr>
                            </thead>
                            <tbody class="text-[#D4D4D4]">
                                <% if (typeof inboundData !=='undefined' && inboundData.length> 0) { %>
                                    <% inboundData.forEach(item=> { %>
                                        <tr class="data-row border-b border-[#182642] hover:bg-[#182642]/30 transition group">
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                TR-<%= item.trans_id %>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <div class="flex items-center gap-2 lg:gap-3">
                                                    <div class="w-6 h-6 lg:w-7 lg:h-7 bg-white rounded-full flex items-center justify-center p-1 shadow-sm shrink-0 overflow-hidden">
                                                        <img src="/images/<%= item.prod_img %>" onerror="this.onerror=null; this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/c/c7/Intel_Core_i7_logo.svg/512px-Intel_Core_i7_logo.svg.png'" class="object-contain w-full h-full">
                                                    </div>
                                                    <span class="truncate-text"><%= item.prod_name %></span>
                                                </div>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.brand %>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.prod_code %>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.prod_type %>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= new Date(item.date_time).toLocaleString('th-TH', { dateStyle: 'short' , timeStyle: 'short' }) %>น.
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.sender || '-' %>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4">
                                                <%= item.emp_firstname %> <%= item.emp_lastname %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="8" class="text-center py-10 text-gray-500">ไม่พบข้อมูลสินค้าเข้า</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>

                    <div id="tab-outbound" class="tab-content hidden min-w-[800px]">
                        <table class="w-full text-left text-xs lg:text-[13px] whitespace-nowrap">
                            <thead class="bg-[#182642] text-[#69B4E3]">
                                <tr>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">ID</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">ชื่อสินค้า</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">แบรนด์</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">รหัสสินค้า</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">ประเภท</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">วันที่ เวลา</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">ผู้ขอเบิก</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal">เจ้าหน้าที่ยืนยัน</th>
                                </tr>
                            </thead>
                            <tbody class="text-[#D4D4D4]">
                                <% if (typeof outboundData !=='undefined' && outboundData.length> 0) { %>
                                    <% outboundData.forEach(item=> { %>
                                        <tr class="data-row border-b border-[#182642] hover:bg-[#182642]/30 transition group">
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                TR-<%= item.trans_id %>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <div class="flex items-center gap-2 lg:gap-3">
                                                    <div class="w-6 h-6 lg:w-7 lg:h-7 bg-white rounded-full flex items-center justify-center p-1 shadow-sm shrink-0 overflow-hidden">
                                                        <img src="/images/<%= item.prod_img %>" onerror="this.onerror=null; this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/c/c7/Intel_Core_i7_logo.svg/512px-Intel_Core_i7_logo.svg.png'" class="object-contain w-full h-full">
                                                    </div>
                                                    <span class="truncate-text"><%= item.prod_name %></span>
                                                </div>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.brand %>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.prod_code %>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.prod_type %>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= new Date(item.date_time).toLocaleString('th-TH', { dateStyle: 'short' , timeStyle: 'short' }) %>น.
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.requester || '-' %>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4">
                                                <%= item.emp_firstname %> <%= item.emp_lastname %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="8" class="text-center py-10 text-gray-500">ไม่พบข้อมูลการเบิกจ่าย</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>

                    <div id="tab-adjust" class="tab-content hidden min-w-[800px]">
                        <table class="w-full text-left text-xs lg:text-[13px] whitespace-nowrap">
                            <thead class="bg-[#182642] text-[#69B4E3]">
                                <tr>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">ID</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">ชื่อสินค้า</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">แบรนด์</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">รหัสสินค้า</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">ประเภท</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">วันที่ เวลา</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50 text-center">จำนวนที่ปรับ</th>
                                    <th class="px-4 lg:px-5 py-3 lg:py-4 font-normal border-r border-[#2A354D]/50">เจ้าหน้าที่แก้ไข</th>
                                </tr>
                            </thead>
                            <tbody class="text-[#D4D4D4]">
                                <% if (typeof adjustData !=='undefined' && adjustData.length> 0) { %>
                                    <% adjustData.forEach(item=> { %>
                                        <tr class="data-row border-b border-[#182642] hover:bg-[#182642]/30 transition group">
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                TR-<%= item.trans_id %>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <div class="flex items-center gap-2 lg:gap-3">
                                                    <div class="w-6 h-6 lg:w-7 lg:h-7 bg-white rounded-full flex items-center justify-center p-1 shrink-0 overflow-hidden">
                                                        <img src="/images/<%= item.prod_img %>" onerror="this.onerror=null; this.src='https://upload.wikimedia.org/wikipedia/commons/thumb/c/c7/Intel_Core_i7_logo.svg/512px-Intel_Core_i7_logo.svg.png'" class="object-contain w-full h-full">
                                                    </div>
                                                    <span class="truncate-text"><%= item.prod_name %></span>
                                                </div>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.brand %>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.prod_code %>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= item.prod_type %>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50">
                                                <%= new Date(item.date_time).toLocaleString('th-TH', { dateStyle: 'short' , timeStyle: 'short' }) %>น.
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4 border-r border-[#182642] group-hover:border-[#2A354D]/50 text-center font-medium">
                                                <%= item.amount %>
                                            </td>
                                            <td class="px-4 lg:px-5 py-3 lg:py-4">
                                                <%= item.emp_firstname %> <%= item.emp_lastname %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="8" class="text-center py-10 text-gray-500">ไม่พบข้อมูลการปรับแก้ไข</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>

                </div>

                <div class="flex flex-col sm:flex-row justify-between items-center mt-4 lg:mt-6 text-xs lg:text-[13px] text-[#999] gap-4">
                    <div class="flex items-center gap-2 lg:gap-3">
                        จำนวนแถวต่อ 1 หน้า
                        <select id="pageLimit" onchange="changeLimit()"
                            class="bg-[#182642] border border-[#2A354D] text-white rounded px-2 py-1 outline-none focus:border-[#69B4E3] cursor-pointer">
                            <option value="10" class="text-white" selected>10</option>
                            <option value="20" class="text-white">20</option>
                            <option value="50" class="text-white">50</option>
                        </select>
                    </div>

                    <div id="pagination-buttons" class="flex flex-wrap justify-center items-center gap-1 lg:gap-2">
                        </div>
                </div>

            </div>
        </div>

        <script>
            const counts = {
                inbound: typeof inboundData !== 'undefined' ? inboundData.length : 0 ,
                outbound: typeof outboundData !== 'undefined' ? outboundData.length : 0 ,
                adjust: typeof adjustData !== 'undefined' ? adjustData.length : 0 
            };

            let currentTab = 'inbound';
            let currentPage = 1;
            let rowsPerPage = 10;

            function switchTab(tabId) {
                const contents = document.querySelectorAll('.tab-content');
                contents.forEach(content => {
                    content.classList.remove('block');
                    content.classList.add('hidden');
                });

                const buttons = document.querySelectorAll('.tab-btn');
                buttons.forEach(btn => {
                    btn.className = "tab-btn whitespace-nowrap flex-shrink-0 bg-[#0A1020] text-[#7A839E] hover:text-white px-6 lg:px-10 py-3 font-medium rounded-t-lg border-b-0 hover:bg-[#182642]/50 transition-colors text-sm lg:text-base";
                });

                document.getElementById('tab-' + tabId).classList.remove('hidden');
                document.getElementById('tab-' + tabId).classList.add('block');
                
                document.getElementById('btn-' + tabId).className = "tab-btn whitespace-nowrap flex-shrink-0 bg-[#182642] text-white px-6 lg:px-10 py-3 font-medium rounded-t-lg border-b-0 shadow-[0_-5px_10px_rgba(0,0,0,0.1)] transition-colors text-sm lg:text-base";

                const summaryText = document.getElementById('dynamic-summary-text');
                if (tabId === 'inbound') summaryText.textContent = `รับเข้าทั้งหมด ${counts.inbound}`;
                else if (tabId === 'outbound') summaryText.textContent = `สินค้าเบิกทั้งหมด ${counts.outbound}`;
                else if (tabId === 'adjust') summaryText.textContent = `ปรับแก้ไขทั้งหมด ${counts.adjust}`;

                currentTab = tabId;
                currentPage = 1;
                updatePagination();
            }

            function applyFilters() {
                const startDate = document.getElementById('startDate').value;
                const endDate = document.getElementById('endDate').value;
                const searchInput = document.getElementById('searchInput').value;

                let url = new URL(window.location.href);

                if (startDate) url.searchParams.set('start', startDate);
                else url.searchParams.delete('start');

                if (endDate) url.searchParams.set('end', endDate);
                else url.searchParams.delete('end');

                if (searchInput) url.searchParams.set('search', searchInput);
                else url.searchParams.delete('search');

                window.location.href = url.href;
            }

            function handleSearchEnter(e) {
                if (e.key === 'Enter') {
                    applyFilters();
                }
            }

            function initPagination() {
                const limitSelect = document.getElementById('pageLimit');
                if (limitSelect) rowsPerPage = parseInt(limitSelect.value);
                updatePagination();
            }

            function changeLimit() {
                const limitSelect = document.getElementById('pageLimit');
                rowsPerPage = parseInt(limitSelect.value);
                currentPage = 1; 
                updatePagination();
            }

            function changePage(page) {
                currentPage = page;
                updatePagination();
            }

            function updatePagination() {
                const tbody = document.querySelector(`#tab-${currentTab} tbody`);
                if (!tbody) return;

                const rows = tbody.querySelectorAll('tr.data-row');
                const totalRows = rows.length;
                
                const totalPages = Math.ceil(totalRows / rowsPerPage) || 1;

                if (currentPage > totalPages) currentPage = totalPages;
                if (currentPage < 1) currentPage = 1;

                const startIndex = (currentPage - 1) * rowsPerPage;
                const endIndex = startIndex + rowsPerPage;

                rows.forEach((row, index) => {
                    if (index >= startIndex && index < endIndex) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });

                renderPaginationControls(totalPages);
            }

            function renderPaginationControls(totalPages) {
                const container = document.getElementById('pagination-buttons');
                if (!container) return;

                let html = '';

                const isFirstPage = currentPage === 1;
                html += `<button onclick="changePage(${currentPage - 1})" class="w-6 h-6 lg:w-7 lg:h-7 flex items-center justify-center hover:text-white transition ${isFirstPage ? 'opacity-30 cursor-not-allowed pointer-events-none' : ''}"><i class="fa-solid fa-caret-left"></i></button>`;

                let startPage = Math.max(1, currentPage - 1);
                let endPage = Math.min(totalPages, currentPage + 1);

                if (currentPage === 1) endPage = Math.min(totalPages, 3);
                if (currentPage === totalPages) startPage = Math.max(1, totalPages - 2);

                if (startPage > 1) {
                    html += `<button onclick="changePage(1)" class="w-6 h-6 lg:w-7 lg:h-7 flex items-center justify-center hover:text-white transition">1</button>`;
                    if (startPage > 2) html += `<span class="px-1 text-[#999]">...</span>`;
                }

                for (let i = startPage; i <= endPage; i++) {
                    if (i === currentPage) {
                        html += `<button class="w-6 h-6 lg:w-7 lg:h-7 border border-[#2A354D] rounded flex items-center justify-center text-white bg-[#182642]">${i}</button>`;
                    } else {
                        html += `<button onclick="changePage(${i})" class="w-6 h-6 lg:w-7 lg:h-7 flex items-center justify-center hover:text-white transition">${i}</button>`;
                    }
                }

                if (endPage < totalPages) {
                    if (endPage < totalPages - 1) html += `<span class="px-1 text-[#999]">...</span>`;
                    html += `<button onclick="changePage(${totalPages})" class="w-6 h-6 lg:w-7 lg:h-7 flex items-center justify-center hover:text-white transition">${totalPages}</button>`;
                }

                const isLastPage = currentPage === totalPages;
                html += `<button onclick="changePage(${currentPage + 1})" class="w-6 h-6 lg:w-7 lg:h-7 flex items-center justify-center hover:text-white transition ${isLastPage ? 'opacity-30 cursor-not-allowed pointer-events-none' : ''}"><i class="fa-solid fa-caret-right"></i></button>`;
                
                html += `<button onclick="changePage(${totalPages})" class="w-6 h-6 lg:w-7 lg:h-7 flex items-center justify-center hover:text-white transition ${isLastPage ? 'opacity-30 cursor-not-allowed pointer-events-none' : ''}"><i class="fa-solid fa-forward-step"></i></button>`;

                container.innerHTML = html;
            }

            window.onload = () => {
                initPagination();
            };

        </script>

</body>

</html>