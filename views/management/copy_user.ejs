<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Management</title>
    <style>
        /* เปลี่ยนสีพื้นหลัง CSS ให้ตรงกับ Three.js */
        body { margin: 0; overflow: hidden; background-color: #0E1324; }
        canvas { display: block; }
    </style>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdn-uicons.flaticon.com/uicons-bold-rounded/css/uicons-bold-rounded.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=SN+Pro:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/font.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/flowbite@latest/dist/flowbite.min.js"></script>
</head>
<body>
    
    <div class="relative z-20 pointer-events-none">
        <%- include('../partials/header_with_path', { path1 : "การจัดการผู้ใช้", url_1 : "/user_management"}) %>
    </div>
    <div class="absolute top-[17%] left-[12%]">
        <p class="text-white text-[40px]">การจัดการผู้ใช้</p>
        <p class="text-gray-400 text-[15px] font-light">เพิ่ม / แก้ไข / ลบ / กำหนดสิทธิ์</p>
        <p class="text-gray-400 text-[15px] font-light">รวมถึงควบคุมการเข้าถึงฟังก์ชันต่าง ๆ ของผู้ใช้งาน ได้ที่นี่</p>
        
    </div>

    <img class="fixed w-70 right-10" src="/images/chklist.png" alt="">

    <div class="absolute top-[37%] inset-x-[12%] right-[10%] flex items-center">
        <p class="text-white text-[20px]">ผู้ใช้ทั้งหมด</p>
        <p id="amount_user"></p>
                
        <div class="flex items-center ml-auto gap-5">

            <!-- Search Bar -->
            <div class="relative flex h-14 w-[500px] items-center overflow-hidden rounded-full border border-[#4BA3E3]/20 bg-transparent">
                <input type="text" placeholder="ค้นหา ชื่อ-นามสกุล พนักงาน" 
                    class="h-full flex-1 bg-transparent px-8 text-white placeholder-gray-500 outline-none"
                />

                <div class="relative h-full w-32 shrink-0">
                    <div class="absolute inset-0 bg-[#1B3563]" style="clip-path: polygon(5% 0%, 60% 0%, 40% 50%, 35% 50%);"></div>
                    <div class="absolute inset-0 bg-[#4BA3E3]/50" style="clip-path: polygon(55% 15%, 35% 50%, 60% 100%, 6% 100%);"></div>
                    <button 
                        class="absolute inset-0 flex items-center justify-end bg-gradient-to-r from-[#3fa9f5] to-[#1c92d2] text-white hover:brightness-110 transition-all"
                        style="clip-path: polygon(35% 50%, 60% 0%, 100% 0%, 100% 100%, 60% 100%);">
                        <i class="fa-solid fa-magnifying-glass text-2xl mr-8"></i>
                    </button>
                </div>
            </div>

            <!-- Button -->
            <button class="text-[white] text-[20px] flex justify-center items-center w-[132px] h-[50px] border border-[#4BA3E3]/50 rounded-[11px] bg-transparent gap-3">
                <i class="fi fi-br-bars-filter mt-2"></i>
                กรอง</button>
            <button data-modal-target="add-user-modal" data-modal-toggle="add-user-modal"
                class="text-[white] text-[20px] flex justify-center items-center w-[132px] h-[50px] rounded-[11px] bg-[#E2A829] gap-3">
                <i class="fa-solid fa-plus" style="color: rgb(255, 255, 255);"></i>
                เพิ่มผู้ใช้
            </button>
        </div>

    </div>

    <!-- User Table -->
    <div id="tableContainer" class="relative z-10 transition-transform duration-300">

        <div class="rounded-2xl overflow-hidden ml-[12%] mt-[8%]" style="width: 1147px;">
            <table class="w-full table-fixed  shadow-2xl rounded-2xl border border-[#4BA3E3]/20 border-separate border-spacing-0">
                <thead>
                    <tr class="bg-[#1B3563] text-white">
                        <th class="py-4 px-5 text-left" style="width: 55px;">
                            <input type="checkbox" id="checkAll" class="custom-check" />
                        </th>
                        <th class="py-4 px-4 text-left text-[18px] font-medium">ชื่อผู้ใช้งาน</th>
                        <th class="py-4 px-4 text-left text-[18px] font-medium" style="width: 280px;">บทบาท</th>
                        <th class="py-4 px-4 text-left text-[18px] font-medium" style="width: 220px;">จัดการผู้ใช้</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (employees.length === 0) { %>
                        <tr>
                            <td colspan="4" class="text-center text-gray-400 py-28 text-xl border-none">
                                <i class="fas fa-inbox text-5xl mb-4 block text-gray-600"></i>
                                <span class="font-light">ไม่พบรายชื่อผู้จำหน่ายที่คุณค้นหา</span>
                            </td>
                        </tr>
                    <% } else { %>
                        <% employees.forEach((emp) => { %>
                            <tr class="sup-row border-t border-[#2a3a6e]/60 hover:bg-[#1e2b50]/50 transition-colors">
                                <td class="py-4 px-5 border-t border-[#4BA3E3]/20">
                                    <input type="checkbox" name="selected" value="<%= emp.emp_id %>" class="row-check custom-check" />
                                </td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">
                                    <span class="text-white text-[16px]"><%= emp.emp_firstname %> <%= emp.emp_lastname%></span>
                                </td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">
                                    <span class="text-white text-[16px]"><%= emp.emp_role %></span>
                                </td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">
                                    <div class="flex gap-4">
                                        <button onclick="openEditModal(<%= emp.emp_id %>, `<%= emp.emp_firstname %>`, `<%= emp.emp_role %>`)"
                                            class="bg-[#4BA3E3] hover:bg-[#2C8BD0] text-white px-4 py-2 rounded-lg font-normal text-[14px] transition-colors shadow flex items-center gap-2">
                                            <i class="fas fa-pen-to-square text-s"></i> แก้ไข
                                        </button>
                                        <button onclick="confirmDelete(<%= emp.emp_id %>, '<%= emp.emp_firstname %>')"
                                            class="bg-[#FF0000] hover:bg-[#DC2626] text-white px-4 py-2 rounded-lg font-normal text-[14px] transition-colors shadow flex items-center gap-2">
                                            <i class="fas fa-trash text-xs"></i> ลบ
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>

                        <% for (let i = employees.length; i < limit; i++) { %>
                            <tr>
                                <td class="py-4 px-5 border-t border-[#4BA3E3]/20">&nbsp;</td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">&nbsp;</td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">&nbsp;</td>
                                <td class="py-4 px-4 border-t border-[#4BA3E3]/20">&nbsp;</td>
                            </tr>
                        <% } %>
                    <% } %>
                </tbody>
            </table>
            
        </div>
    </div>




    <div id="add-user-modal" tabindex="-1" 
        class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50">
        
        <form action="/user_management" method="POST"
            class="flex flex-col bg-white rounded-xl shadow-lg w-[750px] h-[610px] p-6">
            
            <!-- Header -->
            <div class="flex justify-between">
                <p class="text-md font-normal text-[#9E9E9E] ml-5 mt-3">แก้ไขข้อมูล</p>
                <button data-modal-hide="add-user-modal" class="mr-3">
                        <i class="fa-solid fa-xmark text-2xl" style="color: #9E9E9E;"></i>
                </button>
            </div>
            <h1 class="text-[36px] ml-5">เพิ่มผู้ใช้งาน</h1>

            <!-- Body -->
            <div class="flex gap-3 ml-5 mt-8">
                <img class="w-[260px] h-[260px] rounded-full object-cover" src="/images/user.png" alt="">
                <div class="flex flex-col w-[50%] ml-8">
                    
                    <span class="flex gap-3 mt-2">
                        <div>
                            <label for="username" class="text-[16px] text-[#9E9E9E]">ชื่อจริง</label>
                            <input type="text" id="emp_firstname" name="emp_firstname" class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%] text-[#1B3563] mt-1">
                        </div>
                        <div>
                            <label for="username" class="text-[16px] text-[#9E9E9E] mt-2">นามสกุล</label>
                            <input type="text" id="emp_lastname" name="emp_lastname" class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%] text-[#1B3563] mt-1">
                        </div>
                    </span>

                    <label for="username" class="text-[16px] text-[#9E9E9E] mt-2">ชื่อผู้ใช้</label>
                    <input type="text" id="username" name="username" class="bg-[#F5F5F5] border-b-2 border-[#1B3563] h-[40px] outline-0 p-3 w-[100%] text-[#1B3563] mt-1">
                
                    <!-- บทบาท -->
                    <div class="mt-2">
                        <label class="block text-[#9E9E9E] text-[16px]">บทบาท</label>

                        <!-- แสดง Tag บทบาทที่เลือกแล้ว -->
                        <div id="selectedRoles" class="flex flex-wrap gap-3 mb-4 mt-2">
                        <!-- Tag จะถูกเพิ่มที่นี่ด้วย JavaScript -->
                        </div>

                        <!-- Hidden inputs สำหรับส่งค่า roles ไปกับ form -->
                        <div id="hiddenInputs"></div>

                        <!-- ปุ่มเพิ่มบทบาท + Dropdown -->
                        <div class="relative inline-block">
                            <button
                                type="button"
                                id="addRoleBtn"
                                class="border-2 border-dashed border-sky-400 text-sky-500 
                                    px-6 py-2 rounded-full hover:bg-sky-50 
                                    transition-colors flex items-center gap-2 font-medium"
                            >
                                <i class="fa-solid fa-plus" style="color: sky-400;"></i>
                                เพิ่มบทบาท
                            </button>
                            <!-- Dropdown เลือกบทบาท -->
                            <div
                                id="roleDropdown"
                                class="hidden absolute left-0 top-full mt-2 bg-white border border-gray-200 
                                    rounded-xl shadow-xl z-10 overflow-hidden min-w-[200px]"
                            >
                                <button type="button" data-role="manager"
                                class="role-option w-full text-left px-5 py-3 hover:bg-purple-50 
                                        text-gray-700 transition-colors text-base font-medium 
                                        border-b border-gray-100">
                                ผู้จัดการ
                                </button>
                                <button type="button" data-role="sysadmin"
                                class="role-option w-full text-left px-5 py-3 hover:bg-red-50 
                                        text-gray-700 transition-colors text-base font-medium 
                                        border-b border-gray-100">
                                เจ้าหน้าที่ระบบ
                                </button>
                                <button type="button" data-role="warehouse"
                                class="role-option w-full text-left px-5 py-3 hover:bg-green-50 
                                        text-gray-700 transition-colors text-base font-medium">
                                เจ้าหน้าที่คลังสินค้า
                                </button>
                            </div>
                        </div>
                    </div>
                
                </div>
            </div>

            <!-- Button -->
            <div class="w-[100%] flex justify-end pt-5 gap-5 mt-auto mb-3 pr-3">
                <button type="submit" class="px-[32px] py-[12px] bg-[#1B3563] rounded-[8px] text-white">
                    ยืนยันการเพิ่ม
                </button>
                <button type="button" data-modal-hide="add-user-modal" class="px-[32px] py-[12px] bg-[#F00] rounded-[8px] text-white">
                    ยกเลิก
                </button>
            </div>
        </form>
    </div>
    
    <script>
        // ===============================
        // กำหนดค่าบทบาท พร้อมสีของแต่ละบทบาท
        // ===============================
        const rolesConfig = {
            manager: {
                label: "ผู้จัดการ",
                bg: "bg-[#8A38F5]/25",
                text: "text-purple-700",
                border: "border-[#8A38F5]",
                closeBg: "bg-purple-400",
                closeHover: "hover:bg-purple-500",
            },
            sysadmin: {
                label: "เจ้าหน้าที่ระบบ",
                bg: "bg-[#EA7987]/25",
                text: "text-red-600",
                border: "border-[#EA7987]",
                closeBg: "bg-red-400",
                closeHover: "hover:bg-red-500",
            },
            warehouse: {
                label: "เจ้าหน้าที่คลังสินค้า",
                bg: "bg-[#69D1BF]/25",
                text: "text-[#69D1BF]",
                border: "border-[#69D1BF]",
                closeBg: "bg-[#69D1BF]",
                closeHover: "hover:bg-[#50B5A3]",
            },
        };

        // เก็บบทบาทที่เลือกแล้ว
        const selectedRoles = new Set();

        // DOM Elements
        const addRoleBtn = document.getElementById("addRoleBtn");
        const roleDropdown = document.getElementById("roleDropdown");
        const selectedRolesContainer = document.getElementById("selectedRoles");
        const hiddenInputsContainer = document.getElementById("hiddenInputs");
        const roleOptions = document.querySelectorAll(".role-option");

        // ===============================
        // เปิด/ปิด Dropdown
        // ===============================
        addRoleBtn.addEventListener("click", (e) => {
            e.stopPropagation();
            roleDropdown.classList.toggle("hidden");
        });

        // ปิด Dropdown เมื่อคลิกข้างนอก
        document.addEventListener("click", (e) => {
            if (!roleDropdown.contains(e.target) && e.target !== addRoleBtn) {
                roleDropdown.classList.add("hidden");
            }
        });

        // ===============================
        // เลือกบทบาทจาก Dropdown
        // ===============================
        roleOptions.forEach((option) => {
            option.addEventListener("click", () => {
                const roleKey = option.getAttribute("data-role");

                // ถ้าเลือกไปแล้ว ไม่ต้องเพิ่มซ้ำ
                if (selectedRoles.has(roleKey)) {
                    roleDropdown.classList.add("hidden");
                    return;
                }

                selectedRoles.add(roleKey);
                renderTags();
                roleDropdown.classList.add("hidden");
                updateDropdownOptions();
            });
        });

        // ===============================
        // สร้าง Tag แสดงบทบาทที่เลือก
        // ===============================
        function renderTags() {
            selectedRolesContainer.innerHTML = "";
            hiddenInputsContainer.innerHTML = "";

            selectedRoles.forEach((roleKey) => {
                const config = rolesConfig[roleKey];

                // สร้าง Tag Element
                const tag = document.createElement("span");
                tag.className = `inline-flex items-center gap-2 px-4 py-2 rounded-full 
                                border border-2 ${config.bg} ${config.text} ${config.border} 
                                text-base font-medium animate-fadeIn`;
                tag.setAttribute("data-role", roleKey);

                tag.innerHTML = `
                ${config.label}
                <button type="button" 
                        class="w-5 h-5 flex items-center justify-center rounded-full 
                                ${config.closeBg} ${config.closeHover} text-white 
                                transition-colors ml-1"
                        onclick="removeRole('${roleKey}')">
                    <i class="fa-solid fa-xmark w-3.5" style="color: rgb(255, 255, 255);"></i>
                </button>
                `;

                selectedRolesContainer.appendChild(tag);

                // สร้าง Hidden Input สำหรับส่งค่าไปกับ Form
                const hiddenInput = document.createElement("input");
                hiddenInput.type = "hidden";
                hiddenInput.name = "roles";
                hiddenInput.value = roleKey;
                hiddenInputsContainer.appendChild(hiddenInput);
            });
        }

        // ===============================
        // ลบบทบาท
        // ===============================
        function removeRole(roleKey) {
            selectedRoles.delete(roleKey);
            renderTags();
            updateDropdownOptions();
        }

        // ===============================
        // ซ่อนตัวเลือกที่เลือกไปแล้วใน Dropdown
        // ===============================
        function updateDropdownOptions() {
            roleOptions.forEach((option) => {
                const roleKey = option.getAttribute("data-role");
                if (selectedRoles.has(roleKey)) {
                    option.classList.add("hidden");
                } else {
                    option.classList.remove("hidden");
                }
            });

            // ถ้าเลือกครบทุกบทบาทแล้ว ซ่อนปุ่มเพิ่ม
            if (selectedRoles.size >= Object.keys(rolesConfig).length) {
                addRoleBtn.classList.add("opacity-50", "pointer-events-none");
            } else {
                addRoleBtn.classList.remove("opacity-50", "pointer-events-none");
            }
        }
    </script>

    <!-- Animation -->
    <!-- <style>
        @keyframes fadeIn {
            from { opacity: 0; transform: scale(0.9); }
            to   { opacity: 1; transform: scale(1); }
        }
        .animate-fadeIn {
            animation: fadeIn 0.2s ease-out;
        }
    </style> -->

</body>
</html>